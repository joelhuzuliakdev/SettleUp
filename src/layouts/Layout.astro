---
import '../styles/global.css';
interface Props {
	title?: string;
}

const { title = "SettleUp" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Dividí gastos con amigos fácilmente" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body class="bg-gray-50 min-h-screen text-gray-900 antialiased">
		<slot />
	</body>
</html>