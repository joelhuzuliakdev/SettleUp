---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SplitApp">
	<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-violet-500 to-indigo-600">
		<div class="text-center text-white px-6">
		<div class="text-6xl mb-4">
			<img src="/logoSettleUp.webp" alt="Logo de la aplicación" class="mx-auto w-24 h-24" />
		</div>
		<h1 class="text-4xl font-bold mb-2">SettleUp</h1>
		<p class="text-violet-200 text-lg mb-8">
			Dividí gastos con amigos, sin drama
		</p>
		<div class="flex flex-col sm:flex-row gap-3 justify-center">
			
			<a href="/login"
			class="bg-white text-violet-600 font-semibold px-6 py-3 rounded-xl hover:bg-violet-50 transition-colors"
			>
			Iniciar sesión
			</a>
			
			<a href="/register"
			class="bg-violet-700 text-white font-semibold px-6 py-3 rounded-xl hover:bg-violet-800 transition-colors border border-violet-400"
			>
			Crear cuenta
			</a>
		</div>
		</div>
	</div>
</Layout>