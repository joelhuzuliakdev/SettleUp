---
import Layout from "../layouts/Layout.astro";

let error = "";

if (Astro.request.method === "POST") {
    try {
        const contentType = Astro.request.headers.get("content-type") ?? "";
        
        let nombre = "";
        let email = "";
        let password = "";

        if (contentType.includes("application/x-www-form-urlencoded") || contentType.includes("multipart/form-data")) {
        const formData = await Astro.request.formData();
        nombre = formData.get("nombre")?.toString() ?? "";
        email = formData.get("email")?.toString() ?? "";
        password = formData.get("password")?.toString() ?? "";
        } else {
        // Leer el body como texto plano y parsearlo manualmente
        const body = await Astro.request.text();
        const params = new URLSearchParams(body);
        nombre = params.get("nombre") ?? "";
        email = params.get("email") ?? "";
        password = params.get("password") ?? "";
        }

        console.log("Datos recibidos:", { nombre, email, password: "***" });

        if (!email || !password) {
        error = "Email y contraseña son requeridos";
        } else if (password.length < 6) {
        error = "La contraseña debe tener al menos 6 caracteres";
        } else {
        const { createClient } = await import("@supabase/supabase-js");
        const supabase = createClient(
            import.meta.env.PUBLIC_SUPABASE_URL,
            import.meta.env.PUBLIC_SUPABASE_ANON_KEY
        );

        const { data, error: authError } = await supabase.auth.signUp({
            email,
            password,
            options: {
            data: { nombre },
            },
        });

        if (authError) {
            console.error("Auth error:", authError);
            error = authError.message.includes("already registered")
            ? "Este email ya está registrado"
            : `Error: ${authError.message}`;
        } else if (data.session) {
            Astro.cookies.set("sb-access-token", data.session.access_token, {
            path: "/",
            httpOnly: true,
            secure: false,
            sameSite: "lax",
            maxAge: 60 * 60 * 24 * 7,
            });

            Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
            path: "/",
            httpOnly: true,
            secure: false,
            sameSite: "lax",
            maxAge: 60 * 60 * 24 * 30,
            });

            return Astro.redirect("/dashboard");
        } else {
            console.log("Sin sesión en data:", data);
            error = "No se pudo crear la sesión. Verificá si el email necesita confirmación.";
        }
        }
    } catch (e) {
        console.error("ERROR REGISTRO:", e);
        error = `Error inesperado: ${e instanceof Error ? e.message : String(e)}`;
    }
}
---

<Layout title="Crear cuenta - SplitApp">
    <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
        <div class="w-full max-w-md">

        <!-- Logo y título -->
        <div class="text-center mb-8">
            <a href="/" class="text-5xl inline-block hover:scale-110 transition-transform">
                <img src="/logoSettleUp.webp" alt="Logo de la aplicación" class="mx-auto w-24 h-24" />
            </a>
            <h1 class="text-2xl font-bold mt-3 text-gray-900">Crear cuenta</h1>
            <p class="text-gray-500 mt-1">Empezá a dividir gastos hoy, es gratis</p>
        </div>

        <!-- Card del formulario -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">

            <!-- Error -->
            {error && (
            <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-4 text-sm flex items-center gap-2">
                <span>⚠️</span>
                <span>{error}</span>
            </div>
            )}

            <form method="POST" enctype="application/x-www-form-urlencoded" class="space-y-4" id="register-form">

            <div>
                <label for="nombre" class="block text-sm font-medium text-gray-700 mb-1">
                Nombre
                </label>
                <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition text-sm"
                />
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                Email
                </label>
                <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="tu@email.com"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition text-sm"
                />
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                Contraseña
                </label>
                <input
                type="password"
                id="password"
                name="password"
                required
                placeholder="Mínimo 6 caracteres"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition text-sm"
                />
            </div>

            <button
                type="submit"
                id="submit-btn"
                class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold py-3 rounded-xl transition-colors text-sm mt-2"
            >
                Crear cuenta
            </button>

            </form>
        </div>

        <p class="text-center text-gray-500 mt-4 text-sm">
            ¿Ya tenés cuenta?{" "}
            <a href="/login" class="text-violet-600 font-medium hover:underline">
            Iniciá sesión
            </a>
        </p>

        </div>
    </div>
</Layout>